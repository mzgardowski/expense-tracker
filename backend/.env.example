# Azure Key Vault (required — app fetches DB credentials from Key Vault at startup)
KEY_VAULT_URL=https://expensetrackerkey.vault.azure.net

# Application
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Only for CLI migrations (data-source.ts) — not used by the running app ---
# DB_HOST=localhost
# DB_PORT=1433
# DB_USERNAME=
# DB_PASSWORD=
# DB_NAME=
# DB_ENCRYPT=true
# DB_TRUST_CERT=false